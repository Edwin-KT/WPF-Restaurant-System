<Page x:Class="ViaEurope.WPF.Views.EmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ViaEurope.WPF.ViewModels"
      Title="Panou Angajat" Background="#f0f0f5">

	<Page.DataContext>
		<vm:EmployeeViewModel/>
	</Page.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="#1a1a2e" Padding="20,16">
			<TextBlock Text="👨‍💼 Panou Angajat — Via Europe"
                       FontSize="20" FontWeight="Bold" Foreground="White"/>
		</Border>

		<!-- Tab Control -->
		<TabControl Grid.Row="1" Margin="16"
                    Background="White">

			<!-- ===== TAB 1: Toate Comenzile ===== -->
			<TabItem Header="📋 Toate Comenzile">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="{Binding Message}"
                               Margin="12,8"
                               FontSize="13"
                               Foreground="{Binding MessageIsError,
                                   Converter={StaticResource BoolToColorConverter}}"/>

					<DataGrid Grid.Row="1"
                              ItemsSource="{Binding AllOrders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Cod" Width="140"
                                Binding="{Binding OrderCode}"/>
							<DataGridTextColumn Header="Client" Width="150"
                                Binding="{Binding User.LastName}"/>
							<DataGridTextColumn Header="Telefon" Width="120"
                                Binding="{Binding User.Phone}"/>
							<DataGridTextColumn Header="Adresă" Width="180"
                                Binding="{Binding User.DeliveryAddress}"/>
							<DataGridTextColumn Header="Data" Width="140"
                                Binding="{Binding OrderDate,
                                    StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>
							<DataGridTextColumn Header="Mâncare" Width="80"
                                Binding="{Binding FoodCost,
                                    StringFormat={}{0:0.00} lei}"/>
							<DataGridTextColumn Header="Transport" Width="80"
                                Binding="{Binding TransportCost,
                                    StringFormat={}{0:0.00} lei}"/>
							<DataGridTextColumn Header="Total" Width="90"
                                Binding="{Binding TotalCost,
                                    StringFormat={}{0:0.00} lei}"/>
							<DataGridTextColumn Header="Status" Width="130"
                                Binding="{Binding Status}"/>
							<DataGridTextColumn Header="Livrare est." Width="100"
                                Binding="{Binding EstimatedDelivery,
                                    StringFormat={}{0:HH:mm}}"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>

			<!-- ===== TAB 2: Comenzi Active ===== -->
			<TabItem Header="🔥 Comenzi Active">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<DataGrid Grid.Row="1"
                              ItemsSource="{Binding ActiveOrders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Cod" Width="140"
                                Binding="{Binding OrderCode}"/>
							<DataGridTextColumn Header="Client" Width="150"
                                Binding="{Binding User.LastName}"/>
							<DataGridTextColumn Header="Telefon" Width="110"
                                Binding="{Binding User.Phone}"/>
							<DataGridTextColumn Header="Adresă" Width="160"
                                Binding="{Binding User.DeliveryAddress}"/>
							<DataGridTextColumn Header="Total" Width="90"
                                Binding="{Binding TotalCost,
                                    StringFormat={}{0:0.00} lei}"/>
							<DataGridTextColumn Header="Status" Width="130"
                                Binding="{Binding Status}"/>
						</DataGrid.Columns>
					</DataGrid>

					<!-- Schimba status -->
					<Border Grid.Row="2" Background="#f8f8f8"
                            BorderBrush="#eee" BorderThickness="0,1,0,0"
                            Padding="16,12">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Schimbă status pentru comanda selectată:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" Foreground="#555"/>
							<ComboBox ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding SelectedStatus}"
                                      Width="180" Margin="0,0,12,0"
                                      VerticalAlignment="Center"/>
							<Button Content="✓ Aplică"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding UpdateOrderStatusCommand}"/>
						</StackPanel>
					</Border>
				</Grid>
			</TabItem>

			<!-- ===== TAB 3: Stoc Scăzut ===== -->
			<TabItem Header="⚠️ Stoc Scăzut">
				<DataGrid ItemsSource="{Binding LowStockDishes}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          Margin="8"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Preparat" Width="*"
                            Binding="{Binding Name}"/>
						<DataGridTextColumn Header="Cantitate totală" Width="150"
                            Binding="{Binding TotalQuantity,
                                StringFormat={}{0:0.##}}"/>
						<DataGridTextColumn Header="Unitate" Width="80"
                            Binding="{Binding TotalUnit}"/>
					</DataGrid.Columns>
				</DataGrid>
			</TabItem>

			<!-- ===== TAB 4: CRUD Categorii ===== -->
			<TabItem Header="🗂️ Categorii">
				<Grid Margin="16">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="300"/>
					</Grid.ColumnDefinitions>

					<!-- Lista -->
					<DataGrid Grid.Column="0"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="0,0,16,0">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Nume" Width="*"
                                Binding="{Binding Name}"/>
							<DataGridTextColumn Header="Descriere" Width="*"
                                Binding="{Binding Description}"/>
						</DataGrid.Columns>
					</DataGrid>

					<!-- Formular adaugare -->
					<Border Grid.Column="1" Style="{StaticResource CardStyle}">
						<StackPanel>
							<TextBlock Text="Adaugă categorie"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#1a1a2e" Margin="0,0,0,16"/>

							<TextBlock Text="Nume *" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
							<TextBox Text="{Binding NewCategoryName,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,12"/>

							<TextBlock Text="Descriere" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
							<TextBox Text="{Binding NewCategoryDesc,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,16"/>

							<Button Content="+ Adaugă"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddCategoryCommand}"
                                    Margin="0,0,0,8"/>

							<Button Content="🗑 Șterge selectata"
                                    Background="#fde8e8" Foreground="#e94560"
                                    BorderThickness="0" Padding="12,8"
                                    Cursor="Hand"
                                    Command="{Binding DeleteCategoryCommand}"/>

							<TextBlock Text="{Binding Message}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap" FontSize="12"
                                       Visibility="{Binding Message,
                                           Converter={StaticResource StringToVisibilityConverter}}">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Style.Triggers>
											<DataTrigger Binding="{Binding MessageIsError}"
                                                         Value="True">
												<Setter Property="Foreground" Value="#e94560"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding MessageIsError}"
                                                         Value="False">
												<Setter Property="Foreground" Value="#2ecc71"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</StackPanel>
					</Border>
				</Grid>
			</TabItem>

			<!-- ===== TAB 5: CRUD Preparate ===== -->
			<TabItem Header="🍽️ Preparate">
				<Grid Margin="16">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="320"/>
					</Grid.ColumnDefinitions>

					<DataGrid Grid.Column="0"
                              ItemsSource="{Binding Dishes}"
                              SelectedItem="{Binding SelectedDish}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="0,0,16,0">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Nume" Width="*"
                                Binding="{Binding Name}"/>
							<DataGridTextColumn Header="Țară" Width="100"
                                Binding="{Binding CountryOfOrigin}"/>
							<DataGridTextColumn Header="Preț" Width="80"
                                Binding="{Binding Price,
                                    StringFormat={}{0:0.00} lei}"/>
							<DataGridTextColumn Header="Porție" Width="80"
                                Binding="{Binding PortionQuantity}"/>
							<DataGridTextColumn Header="Stoc" Width="80"
                                Binding="{Binding TotalQuantity}"/>
							<DataGridTextColumn Header="Categorie" Width="120"
                                Binding="{Binding Category.Name}"/>
						</DataGrid.Columns>
					</DataGrid>

					<!-- Formular -->
					<ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Auto">
						<Border Style="{StaticResource CardStyle}">
							<StackPanel>
								<TextBlock Text="Adaugă preparat"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#1a1a2e" Margin="0,0,0,16"/>

								<TextBlock Text="Nume *" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
								<TextBox Text="{Binding NewDishName,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"
                                         Margin="0,0,0,10"/>

								<TextBlock Text="Țară origine" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
								<TextBox Text="{Binding NewDishCountry,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"
                                         Margin="0,0,0,10"/>

								<TextBlock Text="Preț (lei) *" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
								<TextBox Text="{Binding NewDishPrice,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"
                                         Margin="0,0,0,10"/>

								<TextBlock Text="Cantitate / porție *"
                                           FontWeight="SemiBold" Margin="0,0,0,4"/>
								<Grid Margin="0,0,0,10">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="80"/>
									</Grid.ColumnDefinitions>
									<TextBox Grid.Column="0"
                                             Text="{Binding NewDishPortion,
                                                 UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,8,0"/>
									<ComboBox Grid.Column="1"
                                              SelectedItem="{Binding NewDishPortionUnit}"
                                              VerticalAlignment="Center">
										<ComboBoxItem>g</ComboBoxItem>
										<ComboBoxItem>ml</ComboBoxItem>
										<ComboBoxItem>buc</ComboBoxItem>
									</ComboBox>
								</Grid>

								<TextBlock Text="Stoc total *" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
								<TextBox Text="{Binding NewDishTotal,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"
                                         Margin="0,0,0,10"/>

								<TextBlock Text="Categorie *" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
								<ComboBox ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding NewDishCategory}"
                                          DisplayMemberPath="Name"
                                          Margin="0,0,0,16"/>

								<Button Content="+ Adaugă preparat"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding AddDishCommand}"
                                        Margin="0,0,0,8"/>

								<Button Content="🗑 Șterge selectat"
                                        Background="#fde8e8" Foreground="#e94560"
                                        BorderThickness="0" Padding="12,8"
                                        Cursor="Hand"
                                        Command="{Binding DeleteDishCommand}"/>
							</StackPanel>
						</Border>
					</ScrollViewer>
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Page>