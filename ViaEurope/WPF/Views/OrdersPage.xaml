<Page x:Class="ViaEurope.WPF.Views.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ViaEurope.WPF.ViewModels"
      Title="Comenzile mele" Background="#f0f0f5">

	<Page.DataContext>
		<vm:OrdersViewModel/>
	</Page.DataContext>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="380"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ========== COȘ ========== -->
		<Border Grid.Column="0" Background="White"
                BorderBrush="#eee" BorderThickness="0,0,1,0">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Header cos -->
				<Border Grid.Row="0" Background="#1a1a2e" Padding="20,16">
					<TextBlock Text="🛒 Coșul meu"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
				</Border>

				<!-- Items cos -->
				<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="16">
						<!-- Gol -->
						<TextBlock Text="Coșul este gol."
                                   FontSize="14" Foreground="#aaa"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding CartViewModel.HasItems}"
                                                     Value="False">
											<Setter Property="Visibility" Value="Visible"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>

						<ItemsControl ItemsSource="{Binding CartViewModel.Items}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="#f0f0f0"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,12">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>

											<StackPanel Grid.Column="0">
												<TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#1a1a2e"/>
												<TextBlock FontSize="12"
                                                           Foreground="#888">
                                                    <Run Text="{Binding Mode=OneWay, Path= Quantity}"/>
                                                    <Run Text="×"/>
                                                    <Run Text="{Binding Mode=OneWay, Path= UnitPrice,
                                                        StringFormat={}{0:0.00}}"/>
                                                    <Run Text="lei"/>
												</TextBlock>
											</StackPanel>

											<TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       Foreground="#e94560"
                                                       Margin="12,0">
                                                <Run Text="{Binding Mode=OneWay, Path= Total,
                                                    StringFormat={}{0:0.00}}"/>
                                                <Run Text=" lei"/>
											</TextBlock>

											<Button Grid.Column="2"
                                                    Content="✕"
                                                    Command="{Binding DataContext.CartViewModel.RemoveItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    Foreground="#aaa"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand"/>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</ScrollViewer>

				<!-- Sumar + Plasare -->
				<Border Grid.Row="2" Padding="16"
                        BorderBrush="#eee" BorderThickness="0,1,0,0">
					<StackPanel>
						<Grid Margin="0,0,0,6">
							<TextBlock Text="Subtotal:" Foreground="#555"/>
							<TextBlock HorizontalAlignment="Right"
                                       Foreground="#555">
                                <Run Text="{Binding Mode=OneWay, Path= CartViewModel.Total,
                                    StringFormat={}{0:0.00}}"/>
                                <Run Text=" lei"/>
							</TextBlock>
						</Grid>
						<Grid Margin="0,0,0,6">
							<TextBlock Text="Transport:" Foreground="#555"/>
							<TextBlock HorizontalAlignment="Right"
                                       Foreground="#555">
                                <Run Text="{Binding Mode=OneWay, Path= CartViewModel.DeliveryCost,
                                    StringFormat={}{0:0.00}}"/>
                                <Run Text=" lei"/>
							</TextBlock>
						</Grid>
						<Separator Margin="0,6"/>
						<Grid Margin="0,0,0,16">
							<TextBlock Text="Total:" FontWeight="Bold"
                                       FontSize="16" Foreground="#1a1a2e"/>
							<TextBlock HorizontalAlignment="Right"
                                       FontWeight="Bold" FontSize="16"
                                       Foreground="#e94560">
                                <Run Text="{Binding Mode=OneWay, Path= CartViewModel.GrandTotal,
                                    StringFormat={}{0:0.00}}"/>
                                <Run Text=" lei"/>
							</TextBlock>
						</Grid>

						<!-- Mesaje -->
						<TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#2ecc71" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   Visibility="{Binding SuccessMessage,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>
						<TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#e94560" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   Visibility="{Binding ErrorMessage,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>

						<Button Content="🍽️ Plasează comanda"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding PlaceOrderCommand}"
                                Height="44" FontSize="15"/>
					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- ========== ISTORIC COMENZI ========== -->
		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0" Background="#16213e" Padding="20,16">
				<TextBlock Text="📋 Istoricul comenzilor"
                           FontSize="18" FontWeight="Bold"
                           Foreground="White"/>
			</Border>

			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="16">
				<ItemsControl ItemsSource="{Binding Orders}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,12">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
									</Grid.RowDefinitions>

									<!-- Header comanda -->
									<Grid Grid.Row="0" Margin="0,0,0,10">
										<StackPanel Orientation="Horizontal">
											<TextBlock Text="{Binding OrderCode}"
                                                       FontWeight="Bold"
                                                       FontSize="15"
                                                       Foreground="#1a1a2e"
                                                       Margin="0,0,12,0"/>
											<!-- Status badge -->
											<Border CornerRadius="4" Padding="8,3"
                                                    VerticalAlignment="Center">
												<Border.Style>
													<Style TargetType="Border">
														<Setter Property="Background" Value="#e8f5e9"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding Status}"
                                                                         Value="Anulata">
																<Setter Property="Background" Value="#fde8e8"/>
															</DataTrigger>
															<DataTrigger Binding="{Binding Status}"
                                                                         Value="Inregistrata">
																<Setter Property="Background" Value="#e8f4fd"/>
															</DataTrigger>
															<DataTrigger Binding="{Binding Status}"
                                                                         Value="Se pregateste">
																<Setter Property="Background" Value="#fff3cd"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Border.Style>
												<TextBlock Text="{Binding Status}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#333"/>
											</Border>
										</StackPanel>

										<Button Content="Anulează"
                                                HorizontalAlignment="Right"
                                                Background="#fde8e8"
                                                Foreground="#e94560"
                                                BorderThickness="0"
                                                Padding="10,4"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.CancelOrderCommand,
                                                    RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
									</Grid>

									<!-- Data + livrare -->
									<StackPanel Grid.Row="1" Orientation="Horizontal"
                                                Margin="0,0,0,8">
										<TextBlock Foreground="#888" FontSize="12">
                                            <Run Text="📅"/>
                                            <Run Text="{Binding Mode=OneWay, Path= OrderDate,
                                                StringFormat={}{0:dd MMM yyyy HH:mm}}"/>
										</TextBlock>
										<TextBlock Foreground="#888" FontSize="12"
                                                   Margin="16,0,0,0">
                                            <Run Text="🕐 Livrare est.:"/>
                                            <Run Text="{Binding Mode=OneWay, Path= EstimatedDelivery,
                                                StringFormat={}{0:HH:mm}}"/>
										</TextBlock>
									</StackPanel>

									<!-- Produse -->
									<ItemsControl Grid.Row="2"
                                                  ItemsSource="{Binding OrderItems}"
                                                  Margin="0,0,0,10">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<TextBlock FontSize="13"
                                                           Foreground="#555"
                                                           Margin="0,2">
                                                    <Run Text="•"/>
                                                    <Run Text="{Binding Mode=OneWay, Path= Quantity}"/>
                                                    <Run Text="×"/>
                                                    <Run Text="{Binding Mode=OneWay, Path= Dish.Name}"/>
												</TextBlock>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

									<!-- Costuri -->
									<Grid Grid.Row="3">
										<StackPanel Orientation="Horizontal">
											<TextBlock FontSize="12" Foreground="#888">
                                                <Run Text="Mâncare:"/>
                                                <Run Text="{Binding Mode=OneWay, Path= FoodCost,
                                                    StringFormat={}{0:0.00}}"/>
                                                <Run Text="lei"/>
											</TextBlock>
											<TextBlock FontSize="12" Foreground="#888"
                                                       Margin="12,0">
                                                <Run Text="Transport:"/>
                                                <Run Text="{Binding Mode=OneWay, Path= TransportCost,
                                                    StringFormat={}{0:0.00}}"/>
                                                <Run Text="lei"/>
											</TextBlock>
											<TextBlock FontSize="12" Foreground="#888">
                                                <Run Text="Discount:"/>
                                                <Run Text="{Binding Mode=OneWay, Path= DiscountAmount,
                                                    StringFormat={}{0:0.00}}"/>
                                                <Run Text="lei"/>
											</TextBlock>
										</StackPanel>
										<TextBlock HorizontalAlignment="Right"
                                                   FontWeight="Bold"
                                                   Foreground="#e94560">
                                            <Run Text="Total:"/>
                                            <Run Text="{Binding Mode=OneWay, Path= TotalCost,
                                                StringFormat={}{0:0.00}}"/>
                                            <Run Text="lei"/>
										</TextBlock>
									</Grid>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</Grid>
	</Grid>
</Page>