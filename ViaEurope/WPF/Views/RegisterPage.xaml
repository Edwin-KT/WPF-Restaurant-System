<Page x:Class="ViaEurope.WPF.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ViaEurope.WPF.ViewModels"
      Title="Cont nou" Background="#f5f5f5">

	<Page.DataContext>
		<vm:RegisterViewModel/>
	</Page.DataContext>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid>
			<Border Width="440" VerticalAlignment="Center"
                    Margin="0,30" Background="White"
                    CornerRadius="12" Padding="40">
				<Border.Effect>
					<DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="4"/>
				</Border.Effect>

				<StackPanel>
					<TextBlock Text="🌍" FontSize="48" HorizontalAlignment="Center"/>
					<TextBlock Text="Creare cont" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#1a1a2e"
                               Margin="0,4,0,24"/>

					<!-- Nume + Prenume -->
					<Grid Margin="0,0,0,16">
						<Grid.ColumnDefinitions>
							<ColumnDefinition/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0">
							<TextBlock Text="Prenume *" FontWeight="SemiBold"
                                       Foreground="#333" Margin="0,0,0,6"/>
							<TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"/>
						</StackPanel>
						<StackPanel Grid.Column="2">
							<TextBlock Text="Nume *" FontWeight="SemiBold"
                                       Foreground="#333" Margin="0,0,0,6"/>
							<TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"/>
						</StackPanel>
					</Grid>

					<!-- Email -->
					<TextBlock Text="Email *" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,0,0,6"/>
					<TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

					<!-- Telefon -->
					<TextBlock Text="Telefon" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,0,0,6"/>
					<TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

					<!-- Adresa -->
					<TextBlock Text="Adresă de livrare" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,0,0,6"/>
					<TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

					<!-- Parola -->
					<TextBlock Text="Parolă *" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,0,0,6"/>
					<PasswordBox x:Name="PbPassword" Padding="10,8"
                                 FontSize="14" BorderBrush="#ccc"
                                 BorderThickness="1" Margin="0,0,0,16"/>

					<!-- Confirma parola -->
					<TextBlock Text="Confirmă parola *" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,0,0,6"/>
					<PasswordBox x:Name="PbConfirm" Padding="10,8"
                                 FontSize="14" BorderBrush="#ccc"
                                 BorderThickness="1" Margin="0,0,0,8"/>

					<!-- Eroare / Succes -->
					<TextBlock Text="{Binding ErrorMessage}" Foreground="#e94560"
                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                               Visibility="{Binding ErrorMessage,
                                   Converter={StaticResource StringToVisibilityConverter}}"/>
					<TextBlock Text="{Binding SuccessMessage}" Foreground="#2ecc71"
                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                               Visibility="{Binding SuccessMessage,
                                   Converter={StaticResource StringToVisibilityConverter}}"/>

					<Button Content="Creează cont"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnRegister_Click" Height="42"/>

					<TextBlock Margin="0,20,0,0" HorizontalAlignment="Center"
                               FontSize="13" Foreground="#555">
                        <Run Text="Ai deja cont? "/>
                        <Hyperlink Click="BtnGoLogin_Click">Autentifică-te</Hyperlink>
					</TextBlock>
				</StackPanel>
			</Border>
		</Grid>
	</ScrollViewer>
</Page>