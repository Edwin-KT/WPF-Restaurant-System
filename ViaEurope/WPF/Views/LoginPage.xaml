<Page x:Class="ViaEurope.WPF.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ViaEurope.WPF.ViewModels"
      Title="Autentificare" Background="#f5f5f5">

	<Page.DataContext>
		<vm:LoginViewModel/>
	</Page.DataContext>

	<Grid>
		<Border Width="400" VerticalAlignment="Center"
                Background="White" CornerRadius="12"
                Padding="40">
			<Border.Effect>
				<DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="4"/>
			</Border.Effect>

			<StackPanel>
				<!-- Logo / Titlu -->
				<TextBlock Text="🌍" FontSize="48" HorizontalAlignment="Center"/>
				<TextBlock Text="Via Europe" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1a1a2e"
                           Margin="0,4,0,4"/>
				<TextBlock Text="Autentifică-te în contul tău"
                           FontSize="13" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

				<!-- Email -->
				<TextBlock Text="Email" FontWeight="SemiBold"
                           Foreground="#333" Margin="0,0,0,6"/>
				<TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}"
                         Margin="0,0,0,16"/>

				<!-- Parola -->
				<TextBlock Text="Parolă" FontWeight="SemiBold"
                           Foreground="#333" Margin="0,0,0,6"/>
				<PasswordBox x:Name="PbPassword"
                             Padding="10,8" FontSize="14"
                             BorderBrush="#ccc" BorderThickness="1"
                             Margin="0,0,0,8"/>

				<!-- Eroare -->
				<TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#e94560" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,16"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

				<!-- Buton -->
				<Button Content="Autentificare"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="BtnLogin_Click"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        Height="42"/>

				<TextBlock Margin="0,20,0,0" HorizontalAlignment="Center"
                           FontSize="13" Foreground="#555">
                    <Run Text="Nu ai cont? "/>
                    <Hyperlink Click="BtnGoRegister_Click">Creează unul</Hyperlink>
				</TextBlock>
			</StackPanel>
		</Border>
	</Grid>
</Page>