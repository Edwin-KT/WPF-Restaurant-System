<Page x:Class="ViaEurope.WPF.Views.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ViaEurope.WPF.ViewModels"
      Title="Meniu" Background="#f0f0f5">

	<Page.DataContext>
		<vm:MenuViewModel/>
	</Page.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Search Bar -->
		<Border Grid.Row="0" Background="#1a1a2e" Padding="20,14">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}"
                         Margin="0,0,10,0"
                         x:Name="TxtSearch"/>

				<!-- Tip cautare -->
				<StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
					<RadioButton Content="Denumire" Foreground="White"
                                 IsChecked="{Binding SearchByAllergen,
                                     Converter={StaticResource InverseBoolConverter}}"
                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
					<RadioButton Content="Alergen" Foreground="White"
                                 IsChecked="{Binding SearchByAllergen}"
                                 VerticalAlignment="Center"/>
				</StackPanel>

				<!-- Contine / Nu contine -->
				<StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
					<RadioButton Content="Conține" Foreground="White"
                                 IsChecked="{Binding MustContain}"
                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
					<RadioButton Content="Nu conține" Foreground="White"
                                 IsChecked="{Binding MustContain,
                                     Converter={StaticResource InverseBoolConverter}}"
                                 VerticalAlignment="Center"/>
				</StackPanel>

				<Button Grid.Column="3" Content="🔍 Caută"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,8,0"/>

				<Button Grid.Column="4" Content="✕ Reset"
                        Command="{Binding ClearSearchCommand}"
                        Background="#555" Foreground="White"
                        BorderThickness="0" Padding="12,8"
                        Cursor="Hand"/>
			</Grid>
		</Border>

		<!-- Loading -->
		<TextBlock Grid.Row="1" Text="Se încarcă meniul..."
                   Visibility="{Binding IsLoading,
                       Converter={StaticResource BoolToVisibilityConverter}}"
                   FontSize="16" Foreground="#888"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

		<!-- Error -->
		<TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage,
                       Converter={StaticResource StringToVisibilityConverter}}"
                   FontSize="14" Foreground="#e94560"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

		<!-- Menu List -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading,
                          Converter={StaticResource InverseBoolToVisibilityConverter}}">
			<ItemsControl ItemsSource="{Binding Categories}" Margin="20">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<!-- Categorie -->
						<Border Margin="0,0,0,24">
							<StackPanel>
								<!-- Header categorie -->
								<Border Background="#1a1a2e" CornerRadius="10,10,0,0"
                                        Padding="20,14">
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="🍽️" FontSize="20"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
										<TextBlock Text="{Binding Name}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
									</StackPanel>
								</Border>

								<!-- Preparate din categorie -->
								<Border Background="White" CornerRadius="0"
											Padding="12">		
									<ItemsControl ItemsSource="{Binding Dishes}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Margin="6" CornerRadius="8"
                                                        BorderBrush="#eee"
                                                        BorderThickness="1"
                                                        Padding="16">
													<Grid>
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="*"/>
															<ColumnDefinition Width="Auto"/>
														</Grid.ColumnDefinitions>

														<StackPanel Grid.Column="0">
															<StackPanel Orientation="Horizontal">
																<TextBlock Text="{Binding Name}"
																			   FontSize="16"
																			   FontWeight="SemiBold"
																			   Foreground="#1a1a2e"/>
																<Border Background="#e8f4fd"
																			CornerRadius="4"
																			Padding="6,2"
																			Margin="10,0,0,0"
																			VerticalAlignment="Center">
																	<TextBlock Text="{Binding CountryOfOrigin}"
																				   FontSize="11"
																				   Foreground="#2980b9"/>
																</Border>
																<Border Background="#fde8e8"
																			CornerRadius="4"
																			Padding="6,2"
																			Margin="8,0,0,0"
																			VerticalAlignment="Center">
																	<Border.Style>
																		<Style TargetType="Border">
																			<Setter Property="Visibility" Value="Collapsed"/>
																			<Style.Triggers>
																				<DataTrigger Binding="{Binding TotalQuantity}" Value="0">
																					<Setter Property="Visibility" Value="Visible"/>
																				</DataTrigger>
																			</Style.Triggers>
																		</Style>
																	</Border.Style>
																	<TextBlock Text="Indisponibil"
																			   FontSize="11"
																			   Foreground="#e94560"
																			   FontWeight="SemiBold"/>
																</Border>
															</StackPanel>

															<TextBlock Text="{Binding Description}"
																	   FontSize="12"
																	   Foreground="#888"
																	   Margin="0,4,0,6"
																	   TextWrapping="Wrap"/>

															<StackPanel Orientation="Horizontal">
																<TextBlock Text="⚖️ " FontSize="12"/>
																<TextBlock FontSize="12" Foreground="#555">
																	<Run Text="{Binding PortionQuantity, StringFormat={}{0:0}##}"/>
																	<Run Text="{Binding PortionUnit}"/>
																	<Run Text="/ porție"/>
																</TextBlock>
															</StackPanel>

															<ItemsControl ItemsSource="{Binding Allergens}" Margin="0,6,0,0">
																<ItemsControl.ItemsPanel>
																	<ItemsPanelTemplate>
																		<WrapPanel/>
																	</ItemsPanelTemplate>
																</ItemsControl.ItemsPanel>
																<ItemsControl.ItemTemplate>
																	<DataTemplate>
																		<Border Background="#fff3cd" CornerRadius="4" Padding="6,2" Margin="0,0,4,4">
																			<TextBlock Text="{Binding Name}" FontSize="10" Foreground="#856404"/>
																		</Border>
																	</DataTemplate>
																</ItemsControl.ItemTemplate>
															</ItemsControl>

															<ItemsControl ItemsSource="{Binding Photos}" Margin="0,12,0,0">
																<ItemsControl.ItemsPanel>
																	<ItemsPanelTemplate>
																		<WrapPanel/>
																	</ItemsPanelTemplate>
																</ItemsControl.ItemsPanel>
																<ItemsControl.ItemTemplate>
																	<DataTemplate>
																		<Border CornerRadius="8" Margin="0,0,8,8" 
																				BorderBrush="#ddd" BorderThickness="1" 
																				ClipToBounds="True" Width="80" Height="80"
																				Background="#fafafa">
																			<Image Source="{Binding PhotoPath}" Stretch="UniformToFill"/>
																		</Border>
																	</DataTemplate>
																</ItemsControl.ItemTemplate>
															</ItemsControl>

														</StackPanel>
														<StackPanel Grid.Column="1"
															VerticalAlignment="Center"
															HorizontalAlignment="Right"
															MinWidth="120">
															<TextBlock FontSize="22"
																	   FontWeight="Bold"
																	   Foreground="#e94560"
																	   HorizontalAlignment="Right">
																<Run Text="{Binding Price, StringFormat={}{0:0.00}}"/>
																<Run Text=" lei"/>
															</TextBlock>
															<Button Content="+ Adaugă"
																	Margin="0,8,0,0"
																	Tag="{Binding}"
																	Click="BtnAddToCart_Click">
																<Button.Style>
																	<Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
																		<Setter Property="Visibility" Value="Collapsed"/>
																		<Style.Triggers>
																			<DataTrigger Binding="{Binding DataContext.IsClient, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
																				<Setter Property="Visibility" Value="Visible"/>
																			</DataTrigger>
																		</Style.Triggers>
																	</Style>
																</Button.Style>
															</Button>
														</StackPanel>
													</Grid>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</Border>
								<ItemsControl ItemsSource="{Binding Menus}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Border Margin="6,4,6,6" CornerRadius="8"
                    BorderBrush="#f0d080"
                    BorderThickness="1"
                    Padding="16"
                    Background="White">
												<Grid>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="*"/>
														<ColumnDefinition Width="Auto"/>
													</Grid.ColumnDefinitions>

													<StackPanel Grid.Column="0">
														<!-- Nume + badge MENIU -->
														<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
															<TextBlock Text="{Binding Name, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1a1a2e"/>
															<Border Background="#e8a020" CornerRadius="4"
                                    Padding="6,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
																<TextBlock Text="MENIU COMPUS"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White"/>
															</Border>
														</StackPanel>

														<!-- Descriere -->
														<TextBlock Text="{Binding Description, Mode=OneWay}"
                                   FontSize="12" Foreground="#888"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>

														<!-- Preparatele din meniu -->
														<ItemsControl ItemsSource="{Binding MenuDishes}">
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<StackPanel Orientation="Horizontal" Margin="0,2">
																		<TextBlock Text="• " Foreground="#e8a020"
                                                   FontSize="12" FontWeight="Bold"/>
																		<TextBlock Text="{Binding Dish.Name, Mode=OneWay}"
                                                   FontSize="12" Foreground="#333"
                                                   Margin="0,0,6,0"/>
																		<TextBlock FontSize="12" Foreground="#999">
                                            <Run Text="{Binding PortionQuantity,
                                                Mode=OneWay,
                                                StringFormat={}{0:0.##}}"/>
                                            <Run Text="{Binding PortionUnit, Mode=OneWay}"/>
																		</TextBlock>
																	</StackPanel>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</StackPanel>

													<!-- Pret + buton -->
													<StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                MinWidth="130">
														<TextBlock FontSize="11" Foreground="#888"
                                   HorizontalAlignment="Right"
                                   Text="cu reducere aplicată"/>
														<TextBlock FontSize="22" FontWeight="Bold"
                                   Foreground="#e8a020"
                                   HorizontalAlignment="Right"
                                   Tag="{Binding}"
                                   Loaded="TxtMenuPrice_Loaded"/>
														<Button Content="+ Adaugă meniu"
                                Margin="0,8,0,0"
                                Tag="{Binding}"
                                Click="BtnAddMenuToCart_Click">
															<Button.Style>
																<Style TargetType="Button"
                                       BasedOn="{StaticResource PrimaryButtonStyle}">
																	<Setter Property="Background" Value="#e8a020"/>
																	<Setter Property="Visibility" Value="Collapsed"/>
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding DataContext.IsClient,
                                            RelativeSource={RelativeSource AncestorType=Page}}"
                                            Value="True">
																			<Setter Property="Visibility" Value="Visible"/>
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</Button.Style>
														</Button>
													</StackPanel>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</Page>