<Window x:Class="ViaEurope.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Via Europe" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="600">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="60"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="#1a1a2e">
			<Grid Margin="20,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0"
                           Text="🌍 Via Europe"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

				<StackPanel Grid.Column="2" Orientation="Horizontal"
							VerticalAlignment="Center">
					<Button x:Name="BtnMenu" Content="Meniu"
                            Click="BtnMenu_Click" Margin="4,0"
                            Style="{StaticResource NavButtonStyle}"/>
					<Button x:Name="BtnLogin" Content="Autentificare"
                            Click="BtnLogin_Click" Margin="4,0"
                            Style="{StaticResource NavButtonStyle}"/>
					<Button x:Name="BtnRegister" Content="Cont nou"
                            Click="BtnRegister_Click" Margin="4,0"
                            Style="{StaticResource NavButtonStyle}"/>
					<Button x:Name="BtnOrders" Content="Comenzile mele"
                            Click="BtnOrders_Click" Visibility="Collapsed" Margin="4,0"
                            Style="{StaticResource NavButtonStyle}"/>
					<Button x:Name="BtnCart" Content="🛒 0"
							Click="BtnCart_Click" Margin="4,0"
							Visibility="Collapsed"
							Style="{StaticResource NavButtonStyle}"/>
					<Button x:Name="BtnEmployee" Content="Panou angajat"
                            Click="BtnEmployee_Click" Visibility="Collapsed" Margin="4,0"
                            Style="{StaticResource NavButtonStyle}"/>
					<Button x:Name="BtnLogout" Content="Deconectare"
                            Click="BtnLogout_Click" Visibility="Collapsed" Margin="4,0"
                            Style="{StaticResource NavButtonStyle}"/>
					<TextBlock x:Name="TxtUser" Foreground="#a8dadc"
                               VerticalAlignment="Center" FontSize="13"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Content Frame -->
		<Frame x:Name="MainFrame" Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
	</Grid>
</Window>